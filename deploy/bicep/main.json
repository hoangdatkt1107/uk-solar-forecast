      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('{0}-api', parameters('namePrefix'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "acrLoginServer": {
