{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.6.27763",
      "templateHash": "2361695397485824266"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "gridsight",
      "minLength": 3,
      "maxLength": 11,
      "metadata": {
        "description": "Short prefix for resource names (lowercase, 3-11 chars)."
      }
    },
    "acrName": {
      "type": "string",
      "metadata": {
        "description": "Name of the existing Azure Container Registry (created by the deploy script)."
      }
    },
    "apiImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the API (e.g. myacr.azurecr.io/gridsight-api:latest)."
      }
    },
    "jobImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the serve/retrain job."
      }
    },
    "bronzeHfRepo": {
      "type": "string",
      "metadata": {
        "description": "HuggingFace dataset repo id holding the bronze parquet."
      }
    },
    "hfToken": {
      "type": "securestring",
      "metadata": {
        "description": "HuggingFace token — stored in Key Vault, never in image or env plaintext."
      }
    },
    "apiMinReplicas": {
      "type": "int",
      "defaultValue": 0,
      "minValue": 0,
      "maxValue": 5,
      "metadata": {
        "description": "Min API replicas. 0 = scale-to-zero (near-$0 when idle, ~seconds cold start on first hit); 1 = always-on (instant, ~few $/mo)."
      }
    },
    "serveCron": {
      "type": "string",
      "defaultValue": "0 * * * *",
      "metadata": {
        "description": "Cron for the hourly serve job (UTC). Default: top of every hour."
      }
    },
    "retrainCron": {
      "type": "string",
      "defaultValue": "0 3 * * 0",
      "metadata": {
        "description": "Cron for the weekly retrain job (UTC). Default: Sundays 03:00."
      }
    },
    "enableRetrain": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy the weekly retrain job too."
      }
    },
    "corsOrigins": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "Allowed CORS origins for the API (comma-separated). \"*\" is fine for public read-only."
      }
    }
  },
  "variables": {
    "suffix": "[uniqueString(resourceGroup().id)]",
    "kvName": "[take(format('{0}kv{1}', parameters('namePrefix'), variables('suffix')), 24)]",
    "storageName": "[take(format('{0}st{1}', parameters('namePrefix'), variables('suffix')), 24)]",
    "shareName": "serve",
    "envStorageName": "servefiles",
    "mountPath": "/mnt/serve",
    "kvSecretUri": "[format('https://{0}{1}/secrets/hf-token', variables('kvName'), environment().suffixes.keyvaultDns)]"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-id', parameters('namePrefix'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('namePrefix'))), 'acrpull')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-id', parameters('namePrefix'))), '2023-01-31').principalId]",
