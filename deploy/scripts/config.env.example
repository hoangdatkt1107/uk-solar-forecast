# Copy to config.env and edit. `deploy.sh` sources this.
# config.env is gitignored — do NOT commit real values.

# Azure
RG=gridsight-rg                 # resource group name
LOCATION=uksouth                # region (uksouth is close to the UK grid data)
PREFIX=gridsight                # resource name prefix (3-11 lowercase)
ACR=gridsightacr123             # container registry (globally-unique, alnum only) — pick your own, keep it STABLE
TAG=latest                      # image tag

# Schedules (UTC cron). Hourly serve matches NESO(1h)+PV_Live(30m) and catches every NWP run.
SERVE_CRON="0 * * * *"
RETRAIN_CRON="0 3 * * 0"
# Retrain (~5.5 GiB peak) runs on GitHub Actions, not Azure (this legacy Consumption env
# caps at 4 GiB). Keep false; see .github/workflows/retrain.yml.
ENABLE_RETRAIN=false

# HuggingFace (data lake). HF token is passed from the environment, NOT stored here.
GRIDSIGHT_BRONZE_HF_REPO=your-username/gridsight-bronze
# export GRIDSIGHT_HF_TOKEN=hf_xxx   # set in your shell before running deploy.sh
