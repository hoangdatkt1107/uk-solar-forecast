# Copy to .env and fill in. Used by local runs and docker-compose
# On Azure these come from Key Vault (HF token) and Container App env (the rest).

# HuggingFace dataset repo holding the bronze parquet (data lake stays on HF)
GRIDSIGHT_BRONZE_HF_REPO=your-username/gridsight-bronze
# HuggingFace access token (read; write only needed if you upload bronze)
GRIDSIGHT_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

